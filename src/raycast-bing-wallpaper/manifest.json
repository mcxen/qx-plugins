{
  "id": "raycast-bing-wallpaper",
  "name": "Bing Wallpaper",
  "version": "1.1.0",
  "description": "Browse Bing daily wallpapers and set them as your desktop background.",
  "author": "koinzhang",
  "icon": "extension-icon.png",
  "screenshots": [],
  "platforms": [
    "macos"
  ],
  "keywords": [
    "bing",
    "wallpaper",
    "desktop",
    "background",
    "壁纸",
    "必应"
  ],
  "permissions": [
    "http",
    "open-url",
    "invoke:plugin_run_applescript"
  ],
  "entry": "index.js",
  "commands": [
    {
      "name": "set-bing-wallpaper",
      "title": "Set Bing Wallpaper",
      "description": "Browse and set Bing wallpapers.",
      "icon": "bing-wallpaper-icon.png",
      "keywords": ["bing", "wallpaper", "壁纸"],
      "mode": "view"
    },
    {
      "name": "auto-random-bing-wallpaper",
      "title": "Auto Random Bing Wallpaper",
      "description": "Auto-switch a random Bing wallpaper on an interval.",
      "icon": "random-wallpaper-icon.png",
      "keywords": ["random", "wallpaper", "auto"],
      "mode": "no-view",
      "interval": "5m"
    },
    {
      "name": "auto-switch-bing-wallpaper",
      "title": "Auto Switch Bing Wallpaper",
      "description": "Auto-switch to the latest Bing wallpaper on an interval.",
      "icon": "auto-switch-wallpaper-icon.png",
      "keywords": ["latest", "wallpaper", "auto"],
      "mode": "no-view",
      "interval": "30m"
    }
  ],
  "panel": {
    "title": "Bing Wallpaper",
    "icon": "extension-icon.png",
    "keywords": ["bing", "wallpaper", "壁纸"]
  },
  "min_app_version": "0.4.28"
}
